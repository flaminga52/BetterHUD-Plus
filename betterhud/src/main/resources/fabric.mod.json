{
	"schemaVersion": 1,
	"id": "better-hud",
	"version": "${version}",
	"name": "Better HUD",
	"description": "A comprehensive HUD customization mod for Minecraft 1.20.1",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"environment": "*",
	"entrypoints": {
		"main": [
			"dev.betterhud.BetterHudMod"
		],
		"client": [
			"dev.betterhud.client.BetterHudClient"
		]
	},
	"mixins": [
		"better-hud.mixins.json",
		{
			"config": "better-hud.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.15.11",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
	}
}
